/**
 * @intent Forward locations
 * @description Location rows for Nautobot ingestion testing and initial location mapping.
 * @contract-version v1
 */

@primaryKey(name)
@query
f() =
foreach location in network.locations
select {
  name: location.name,
  city: if isPresent(location.city) then location.city else "",
  country: if isPresent(location.country) then location.country else ""
};
